    function cancelPhoto() { pendingPhotoBase64 = null; document.getElementById("photoPreview").style.display = "none"; }

    // Модальное окно для фото
    let currentModalImage = null;
    function openImageModal(imageUrl) { currentModalImage = imageUrl; document.getElementById("modalImg").src = imageUrl; document.getElementById("photoModal").style.display = "flex"; }
    function closeModal() { document.getElementById("photoModal").style.display = "none"; }
    function saveImage() { if (currentModalImage) { let link = document.createElement('a'); link.download = 'photo.jpg'; link.href = currentModalImage; link.click(); showToast("Фото сохранено"); } }

    // Голосовые сообщения
    function startRecordingTimer() {
        let timerDiv = document.getElementById("recordingTimer");
        let timerText = document.getElementById("timerText");
        timerDiv.style.display = "flex";
        let seconds = 0;
        recordingInterval = setInterval(() => {
            seconds++;
            let mins = Math.floor(seconds / 60);
            let secs = seconds % 60;
            timerText.innerText = `${mins}:${secs.toString().padStart(2, '0')}`;
            if (seconds >= 60) stopRecordingAndSend();
        }, 1000);
    }
    function stopRecordingTimer() { if (recordingInterval) { clearInterval(recordingInterval); recordingInterval = null; } document.getElementById("recordingTimer").style.display = "none"; }
    async function stopRecordingAndSend() {
        if (mediaRecorder && mediaRecorder.state !== "inactive") {
            mediaRecorder.stop();
            stopRecordingTimer();
            isRecording = false;
            let voiceBtn = document.getElementById("voiceBtn");
            voiceBtn.classList.remove("recording");
            voiceBtn.innerHTML = "🎤";
        }
    }
    async function toggleVoiceRecording() {
        if (!currentChatId) { showToast("Сначала откройте чат"); return; }
        if (isRecording) { await stopRecordingAndSend(); return; }
        try {
            let stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream);
            audioChunks = [];
            let startTime = Date.now();
            mediaRecorder.ondataavailable = (event) => { if (event.data.size > 0) audioChunks.push(event.data); };
            mediaRecorder.onstop = async () => {
                let duration = Math.round((Date.now() - startTime) / 1000);
                if (audioChunks.length === 0) { showToast("Запись не удалась"); stream.getTracks().forEach(t => t.stop()); return; }
                let audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                let reader = new FileReader();
                reader.readAsDataURL(audioBlob);
                reader.onloadend = async () => {
                    let messagesRef = db.collection("chats").doc(currentChatId).collection("messages");
                    await messagesRef.add({
                        sender: currentUser, senderName: currentUserData?.name || currentUser,
                        audioUrl: reader.result, duration: duration,
                        time: firebase.firestore.FieldValue.serverTimestamp()
                    });
                    await db.collection("chats").doc(currentChatId).update({ lastMessage: "🎤 Голосовое", lastMessageTime: firebase.firestore.FieldValue.serverTimestamp() });
                    showToast("Голосовое отправлено");
                };
                stream.getTracks().forEach(t => t.stop());
            };
            mediaRecorder.start(100);
            isRecording = true;
            startRecordingTimer();
            let voiceBtn = document.getElementById("voiceBtn");
            voiceBtn.classList.add("recording");
            voiceBtn.innerHTML = "⏹️";
            showToast("Запись... Нажмите ещё раз для отправки");
        } catch(e) { showToast("Ошибка: Нет доступа к микрофону"); }
    }

    // ЗВОНКИ
    async function startCall() {
        if (!currentOtherUser) {
            showToast("Не выбран пользователь");
            return;
        }
        showScreen("callScreen");
        document.getElementById("callAvatar").innerHTML = document.getElementById("chatAvatar").innerHTML;
        document.getElementById("callStatus").innerText = "Вызов...";
        isCallActive = true;
        
        try {
            localStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
            setTimeout(() => {
                if (isCallActive) {
                    document.getElementById("callStatus").innerText = "В сети";
                    showToast("Звонок активен");
                }
            }, 2000);
        } catch(e) {
            showToast("Ошибка доступа к микрофону для звонка");
            endCall();
        }
    }
    
    function toggleMute() {
        if (localStream) {
            let audioTracks = localStream.getAudioTracks();
            audioTracks.forEach(track => {
                track.enabled = !track.enabled;
            });
            let muteBtn = document.getElementById("muteBtn");
            if (audioTracks[0] && !audioTracks[0].enabled) {
                muteBtn.innerHTML = "🔇";
                showToast("Микрофон выключен");
            } else {
                muteBtn.innerHTML = "🔊";
                showToast("Микрофон включён");
            }
        }
    }
    
    function endCall() {
        if (localStream) {
            localStream.getTracks().forEach(track => track.stop());
            localStream = null;
        }
        isCallActive = false;
        showMainScreen();
    }

    // Группы и каналы
    async function loadContactsForGroup() {
        let contactsDiv = document.getElementById("contactsForGroup");
        let snapshot = await db.collection("users").get();
        contactsDiv.innerHTML = "";
        snapshot.forEach(doc => {
            let user = doc.data();
            if (user.userId === currentUser) return;
            let div = document.createElement("div");
            div.className = "list-item";
            div.innerHTML = `<div class="list-item-avatar">👤</div><div class="list-item-info"><div class="list-item-name">${escapeHtml(user.name)}</div></div><div style="margin-left: auto;"><input type="checkbox" value="${user.userId}" class="group-member-checkbox"></div>`;
            contactsDiv.appendChild(div);
        });
    }
    
    async function createGroup() {
        let groupName = document.getElementById("groupName").value.trim();
        let groupLink = document.getElementById("groupLink").value.trim();
        if (!groupName) { showToast("Введите название группы"); return; }
        let checkboxes = document.querySelectorAll(".group-member-checkbox:checked");
        let participants = [currentUser];
        checkboxes.forEach(cb => participants.push(cb.value));
        if (participants.length < 2) { showToast("Добавьте хотя бы одного участника"); return; }
        let chatId = groupLink ? `group_${groupLink}` : "group_" + Date.now();
        await db.collection("chats").doc(chatId).set({ 
            participants, type: "group", name: groupName, link: groupLink || null,
            createdAt: Date.now(), lastMessage: "", admins: [currentUser], owner: currentUser 
        });
        showToast("Группа создана!"); 
        showMainScreen();
    }
    
    async function createChannel() {
        let channelName = document.getElementById("channelName").value.trim();
        let channelLink = document.getElementById("channelLink").value.trim();
        let description = document.getElementById("channelDesc").value.trim();
        if (!channelName) { showToast("Введите название канала"); return; }
        let chatId = channelLink ? `channel_${channelLink}` : "channel_" + Date.now();
        await db.collection("chats").doc(chatId).set({ 
            participants: [currentUser], type: "channel", name: channelName, 
            link: channelLink || null, description: description,
            createdAt: Date.now(), lastMessage: "", owner: currentUser, admins: [currentUser] 
        });
        showToast("Канал создан!"); 
        showMainScreen();
    }

