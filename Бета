    async function sendPhotoMessage() {
        if (!pendingPhotoBase64) return;
        showToast("Отправка фото...");
        let caption = document.getElementById("photoCaption").value;
        let messagesRef = db.collection("chats").doc(currentChatId).collection("messages");
        await messagesRef.add({
            sender: currentUser, senderName: currentUserData?.name || currentUser,
            imageUrl: pendingPhotoBase64, caption: caption,
            time: firebase.firestore.FieldValue.serverTimestamp()
        });
        await db.collection("chats").doc(currentChatId).update({ lastMessage: "📷 Фото", lastMessageTime: firebase.firestore.FieldValue.serverTimestamp() });
