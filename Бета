    function showToast(msg) {
        let toast = document.getElementById("toast");
        toast.innerText = msg;
        toast.style.display = "block";
        setTimeout(() => toast.style.display = "none", 2000);
    }

    function showScreen(screenId) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(screenId).classList.add('active');
        if (screenId === 'mainScreen' && currentUser) { loadChats(); loadContacts(); loadAvatar(); }
    }

    function showMainScreen() {
        if (currentChatId && unsubscribeMessages) { unsubscribeMessages(); currentChatId = null; }
        if (currentAudio) { currentAudio.pause(); currentAudio = null; }
        if (isCallActive) endCall();
        showScreen('mainScreen');
        loadChats();
        loadContacts();
        loadAvatar();
        document.getElementById("searchInput").value = "";
        document.getElementById("searchResults").style.display = "none";
    }

    function showProfileScreen() { loadProfileData(); showScreen('profileScreen'); }
    function escapeHtml(str) { if (!str) return ""; return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','&gt;':'&gt;'}[m])); }

    function loadTheme() { 
        if (localStorage.getItem("theme") === "light") { 
            document.body.classList.add("light"); 
            document.getElementById("themeSwitch")?.classList.add("active"); 
        } 
    }
    function toggleTheme() {
        if (document.body.classList.contains("light")) {
            document.body.classList.remove("light");
            localStorage.setItem("theme", "dark");
            document.getElementById("themeSwitch")?.classList.remove("active");
        } else {
            document.body.classList.add("light");
            localStorage.setItem("theme", "light");
            document.getElementById("themeSwitch")?.classList.add("active");
        }
    }

    // Вкладки
    document.querySelectorAll('.tab').forEach(tab => {
        tab.onclick = () => {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            const tabName = tab.dataset.tab;
            document.getElementById('chatsTab').style.display = tabName === 'chats' ? 'block' : 'none';
            document.getElementById('contactsTab').style.display = tabName === 'contacts' ? 'block' : 'none';
            document.getElementById('callsTab').style.display = tabName === 'calls' ? 'block' : 'none';
            if (tabName === 'contacts') loadContacts();
            if (tabName === 'calls') loadCalls();
        };
    });

    // ПОИСК ПОЛЬЗОВАТЕЛЕЙ С ВОЗМОЖНОСТЬЮ КЛИКА
    const searchInput = document.getElementById("searchInput");
    const searchResults = document.getElementById("searchResults");
    
    searchInput.addEventListener("input", async function(e) {
        const query = e.target.value.toLowerCase().trim();
        if (!query) {
            searchResults.style.display = "none";
            return;
        }
        
        const snapshot = await db.collection("users").get();
        const results = [];
        snapshot.forEach(doc => {
            const user = doc.data();
            if (user.userId !== currentUser && user.name.toLowerCase().includes(query)) {
                results.push(user);
            }
        });
        
        if (results.length > 0) {
            searchResults.innerHTML = results.map(user => `
                <div class="list-item search-result" onclick="createPrivateChat('${user.userId}')">
                    <div class="list-item-avatar">${user.avatarUrl ? `<img src="${user.avatarUrl}">` : "👤"}</div>
                    <div class="list-item-info">
                        <div class="list-item-name">${escapeHtml(user.name)}</div>
                        <div class="list-item-preview">${user.online ? '🟢 в сети' : '⚫ не в сети'}</div>
                    </div>
                </div>
            `).join('');
            searchResults.style.display = "block";
        } else {
            searchResults.innerHTML = '<div style="padding: 16px; color: var(--text-secondary);">Ничего не найдено</div>';
            searchResults.style.display = "block";
        }
    });
    
    document.addEventListener("click", (e) => {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
            searchResults.style.display = "none";
        }
    });

    // Аватарка
    function resizeImage(base64, maxWidth, maxHeight, callback) {
        let img = new Image();
        img.onload = function() {
            let width = img.width, height = img.height;
            if (width > height) { if (width > maxWidth) { height *= maxWidth / width; width = maxWidth; } }
            else { if (height > maxHeight) { width *= maxHeight / height; height = maxHeight; } }
            let canvas = document.createElement('canvas');
            canvas.width = width; canvas.height = height;
            let ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);
            callback(canvas.toDataURL('image/jpeg', 0.7));
        };
        img.src = base64;
    }

    async function uploadAvatar(file) {
        if (!file || !currentUser) return;
        showToast("Обработка аватарки...");
        let reader = new FileReader();
        reader.onload = function(e) {
            resizeImage(e.target.result, 200, 200, async function(resized) {
                await db.collection("users").doc(currentUser).update({ avatarUrl: resized });
                loadAvatar();
                showToast("Аватарка обновлена");
            });
        };
        reader.readAsDataURL(file);
    }

    async function loadAvatar() {
        if (!currentUser) return;
        let userDoc = await db.collection("users").doc(currentUser).get();
        let user = userDoc.data();
        let avatarDiv = document.getElementById("mainAvatar");
        let profileAvatarDiv = document.getElementById("profileAvatar");
        if (user?.avatarUrl) {
            let imgHtml = `<img src="${user.avatarUrl}">`;
            avatarDiv.innerHTML = imgHtml;
            if (profileAvatarDiv) profileAvatarDiv.innerHTML = imgHtml;
        } else {
            avatarDiv.innerHTML = "👤";
            if (profileAvatarDiv) profileAvatarDiv.innerHTML = "👤";
        }
    }

    // Регистрация и вход
    async function register() {
        let name = document.getElementById("regName").value.trim();
        let password = document.getElementById("regPassword").value;
        if (!name || !password) { showToast("Заполните все поля"); return; }
        let userId = "user_" + Date.now() + "_" + Math.random().toString(36).substr(2, 6);
        await db.collection("users").doc(userId).set({
            userId: userId, name: name, password: password,
            bio: "", createdAt: new Date().toISOString(), online: true, lastSeen: new Date()
        });
        currentUser = userId;
        currentUserData = { userId, name, bio: "" };
        localStorage.setItem("messenger_user", userId);
        loadAvatar();
        showMainScreen();
        updateOnlineStatus(true);
        setInterval(() => updateOnlineStatus(true), 30000);
        showToast("Добро пожаловать!");
    }

    async function login() {
        let name = document.getElementById("loginName").value.trim();
        let password = document.getElementById("loginPassword").value;
        if (!name || !password) { showToast("Введите имя и пароль"); return; }
        let snapshot = await db.collection("users").where("name", "==", name).where("password", "==", password).get();
        if (snapshot.empty) { showToast("Неверное имя или пароль"); return; }
        let userDoc = snapshot.docs[0];
        currentUser = userDoc.id;
        currentUserData = userDoc.data();
        localStorage.setItem("messenger_user", currentUser);
        loadAvatar();
        showMainScreen();
        updateOnlineStatus(true);
        setInterval(() => updateOnlineStatus(true), 30000);
        showToast("Добро пожаловать!");
    }

    async function logout() {
        await updateOnlineStatus(false);
        if (isCallActive) endCall();
        currentUser = null; currentUserData = null;
        localStorage.removeItem("messenger_user");
        showScreen("authScreen");
    }

    async function updateOnlineStatus(isOnline) {
        if (!currentUser) return;
        await db.collection("users").doc(currentUser).update({ 
            online: isOnline, 
            lastSeen: firebase.firestore.FieldValue.serverTimestamp() 
        });
    }

    async function loadProfileData() {
        let userDoc = await db.collection("users").doc(currentUser).get();
        let user = userDoc.data();
        document.getElementById("profileName").innerText = user.name;
        document.getElementById("profileBio").innerText = user.bio || "";
        document.getElementById("profileNameValue").innerText = user.name;
        document.getElementById("profileBioValue").innerText = user.bio || "Добавить описание";
        let avatarDiv = document.getElementById("profileAvatar");
        if (user?.avatarUrl) { avatarDiv.innerHTML = `<img src="${user.avatarUrl}">`; }
        else { avatarDiv.innerHTML = "👤"; }
    }

    function editField(field) {
        editFieldType = field;
        let titles = { name: 'Редактировать имя', bio: 'Редактировать описание' };
        document.getElementById("editTitle").innerText = titles[field];
        let currentVal = currentUserData?.[field] || "";
        document.getElementById("editValue").value = currentVal;
        showScreen("editScreen");
    }

    async function saveEdit() {
        let newValue = document.getElementById("editValue").value.trim();
        let updateData = {};
        if (editFieldType === 'name') updateData.name = newValue;
        else if (editFieldType === 'bio') updateData.bio = newValue;
        if (Object.keys(updateData).length) await db.collection("users").doc(currentUser).update(updateData);
        currentUserData = (await db.collection("users").doc(currentUser).get()).data();
        showProfileScreen();
        showToast("Профиль обновлён");
    }

    async function changePassword() {
        showScreen("passwordScreen");
    }
    
    async function changePasswordSave() {
        let oldPass = document.getElementById("oldPassword").value;
        let newPass = document.getElementById("newPassword").value;
        let confirmPass = document.getElementById("confirmPassword").value;
        
        if (currentUserData.password !== oldPass) {
            showToast("Неверный старый пароль");
            return;
        }
        if (newPass !== confirmPass) {
            showToast("Пароли не совпадают");
            return;
        }
        if (newPass.length < 4) {
            showToast("Пароль должен быть не менее 4 символов");
            return;
        }
        
        await db.collection("users").doc(currentUser).update({ password: newPass });
        currentUserData.password = newPass;
        showToast("Пароль изменён");
        showProfileScreen();
    }

    async function viewOtherProfile() {
        if (!currentOtherUser) return;
        let userDoc = await db.collection("users").doc(currentOtherUser).get();
        let user = userDoc.data();
        document.getElementById("otherProfileName").innerText = user.name;
        document.getElementById("otherProfileBio").innerText = user.bio || "";
        let avatarDiv = document.getElementById("otherProfileAvatar");
        if (user?.avatarUrl) { avatarDiv.innerHTML = `<img src="${user.avatarUrl}">`; }
        else { avatarDiv.innerHTML = "👤"; }
        showScreen("otherProfileScreen");
    }

    async function loadChats() {
        if (!currentUser) return;
        let chatsRef = db.collection("chats").where("participants", "array-contains", currentUser);
        let snapshot = await chatsRef.get();
        let chatsList = document.getElementById("chatsList");
        chatsList.innerHTML = "";
        existingChats.clear();
        
        if (snapshot.empty) { chatsList.innerHTML = '<div style="padding: 16px; color: var(--text-secondary); text-align: center;">Нет чатов</div>'; return; }
        
        for (let doc of snapshot.docs) {
            let chat = doc.data();
            let chatId = doc.id;
            let chatName = chat.name || "";
            let isGroup = chat.type === "group";
            let isChannel = chat.type === "channel";
            let lastMessage = chat.lastMessage || "Новое сообщение";
            let uniqueKey = "";
            
            if (!isGroup && !isChannel) {
                let otherUser = chat.participants.find(p => p !== currentUser);
                let userDoc = await db.collection("users").doc(otherUser).get();
                chatName = userDoc.exists ? userDoc.data().name : otherUser;
                uniqueKey = otherUser;
            } else {
                uniqueKey = chatId;
            }
            
            if (existingChats.has(uniqueKey)) continue;
            existingChats.add(uniqueKey);
            
            let div = document.createElement("div");
            div.className = "list-item";
            let icon = isChannel ? "📢" : (isGroup ? "👥" : "👤");
            div.innerHTML = `<div class="list-item-avatar">${icon}</div><div class="list-item-info"><div class="list-item-name">${escapeHtml(chatName)}</div><div class="list-item-preview">${escapeHtml(lastMessage)}</div></div>`;
            div.onclick = () => openChat(chatId, chat, isGroup ? "group" : (isChannel ? "channel" : "private"), !isGroup && !isChannel ? chat.participants.find(p => p !== currentUser) : null);
            chatsList.appendChild(div);
        }
    }

    async function loadContacts() {
        if (!currentUser) return;
        let snapshot = await db.collection("users").get();
        let contactsList = document.getElementById("contactsList");
        contactsList.innerHTML = "";
        snapshot.forEach(doc => {
            let user = doc.data();
            if (user.userId === currentUser) return;
            let div = document.createElement("div");
            div.className = "list-item";
            let statusClass = user.online ? "online" : "offline";
            let statusText = user.online ? "в сети" : "не в сети";
            div.innerHTML = `<div class="list-item-avatar">${user.avatarUrl ? `<img src="${user.avatarUrl}">` : "👤"}</div><div class="list-item-info"><div class="list-item-name">${escapeHtml(user.name)}<span class="online-status ${statusClass}"></span></div><div class="list-item-preview">${statusText}</div></div>`;
            div.onclick = () => createPrivateChat(user.userId);
            contactsList.appendChild(div);
        });
    }

    async function loadCalls() {
        let callsList = document.getElementById("callsList");
        callsList.innerHTML = '<div style="padding: 16px; color: var(--text-secondary); text-align: center;">История звонков пуста</div>';
    }

    window.createPrivateChat = async function(otherUserId) {
        let chatId = [currentUser, otherUserId].sort().join("_");
        let chatRef = db.collection("chats").doc(chatId);
        if (!(await chatRef.get()).exists) {
            await chatRef.set({ participants: [currentUser, otherUserId], type: "private", createdAt: Date.now(), lastMessage: "", admins: [] });
        }
        let userDoc = await db.collection("users").doc(otherUserId).get();
        let chatName = userDoc.exists ? userDoc.data().name : otherUserId;
        openChat(chatId, { name: chatName, participants: [currentUser, otherUserId], type: "private" }, "private", otherUserId);
        searchResults.style.display = "none";
        searchInput.value = "";
    };

    async function openChat(chatId, chatData, type, otherUser = null) {
        if (currentChatId && unsubscribeMessages) unsubscribeMessages();
        if (currentAudio) { currentAudio.pause(); currentAudio = null; }
        currentChatId = chatId;
        currentChatData = chatData;
        currentOtherUser = otherUser;
        document.getElementById("chatTitle").innerHTML = escapeHtml(chatData.name || (type === "group" ? "Группа" : (type === "channel" ? "Канал" : "Чат")));
        document.getElementById("chatAvatar").innerHTML = type === "group" ? "👥" : (type === "channel" ? "📢" : "👤");
        loadMessages();
        showScreen("chatScreen");
    }

    async function showChatInfo() {
        if (!currentChatId) return;
        let chatDoc = await db.collection("chats").doc(currentChatId).get();
        let chat = chatDoc.data();
        let content = document.getElementById("chatInfoContent");
        content.innerHTML = "";
        
        if (chat.type === "group" || chat.type === "channel") {
            let inviteContainer = document.getElementById("inviteLinkContainer");
            let inviteLink = `https://t.me/${chat.link || currentChatId}`;
            document.getElementById("inviteLinkInput").value = inviteLink;
            inviteContainer.style.display = "flex";
        } else {
            document.getElementById("inviteLinkContainer").style.display = "none";
        }
        
        if (chat.type === "group") {
            let statsDiv = document.createElement("div");
            statsDiv.className = "profile-field";
            statsDiv.innerHTML = `<label>Участники</label><value>${chat.participants.length}</value>`;
            content.appendChild(statsDiv);
            
            for (let p of chat.participants) {
                let userDoc = await db.collection("users").doc(p).get();
                let userName = userDoc.exists ? userDoc.data().name : p;
                let isOwner = chat.owner === p;
                let isAdmin = chat.admins?.includes(p);
                let status = userDoc.exists && userDoc.data().online ? "🟢 в сети" : "⚫ не в сети";
                let memberDiv = document.createElement("div");
                memberDiv.className = "list-item";
                memberDiv.innerHTML = `<div class="list-item-avatar">👤</div><div class="list-item-info"><div class="list-item-name">${escapeHtml(userName)}${isOwner ? '<span class="group-owner">Владелец</span>' : (isAdmin ? '<span class="group-admin">Админ</span>' : '')}</div><div class="list-item-preview">${status}</div></div>`;
                content.appendChild(memberDiv);
            }
        } else if (chat.type === "channel") {
            let statsDiv = document.createElement("div");
            statsDiv.className = "profile-field";
            statsDiv.innerHTML = `<label>Подписчики</label><value>${chat.participants?.length || 0}</value>`;
            content.appendChild(statsDiv);
            if (chat.description) {
                let descDiv = document.createElement("div");
                descDiv.className = "profile-field";
                descDiv.innerHTML = `<label>Описание</label><value>${escapeHtml(chat.description)}</value>`;
                content.appendChild(descDiv);
            }
        } else {
            let otherUser = chat.participants.find(p => p !== currentUser);
            let userDoc = await db.collection("users").doc(otherUser).get();
            let user = userDoc.data();
            let status = user?.online ? "🟢 в сети" : "⚫ не в сети";
            content.innerHTML = `
                <div class="profile-field"><label>Имя</label><value>${escapeHtml(user?.name || otherUser)}</value></div>
                <div class="profile-field"><label>О себе</label><value>${escapeHtml(user?.bio || "")}</value></div>
                <div class="profile-field"><label>Статус</label><value>${status}</value></div>
            `;
        }
        showScreen("chatInfoScreen");
    }
    
    function copyInviteLink() {
        let input = document.getElementById("inviteLinkInput");
        input.select();
        document.execCommand("copy");
        showToast("Ссылка скопирована");
    }
    
    async function leaveChat() {
        if (confirm("Покинуть чат?")) {
            await db.collection("chats").doc(currentChatId).update({ participants: firebase.firestore.FieldValue.arrayRemove(currentUser) });
            showMainScreen();
        }
    }

    function createWaveform() {
        let bars = '';
        for (let i = 0; i < 20; i++) {
            let height = 8 + Math.random() * 20;
            bars += `<span class="wave-bar" style="height: ${height}px;"></span>`;
        }
        return bars;
    }
    
    function formatDuration(seconds) {
        let mins = Math.floor(seconds / 60);
        let secs = seconds % 60;
        return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    function loadMessages() {
        if (unsubscribeMessages) unsubscribeMessages();
        let messagesRef = db.collection("chats").doc(currentChatId).collection("messages");
        unsubscribeMessages = messagesRef.orderBy("time", "asc").onSnapshot(snapshot => {
            let container = document.getElementById("chatMessages");
            container.innerHTML = "";
            if (snapshot.empty) { container.innerHTML = '<div style="text-align: center; color: var(--text-secondary);">Нет сообщений</div>'; return; }
            snapshot.forEach(doc => {
                let data = doc.data();
                let isMy = data.sender === currentUser;
                let div = document.createElement("div");
                div.className = `message ${isMy ? 'my-message' : 'other-message'}`;
                if (!isMy) {
                    let nameSpan = document.createElement("div");
                    nameSpan.className = "message-name";
                    nameSpan.innerText = data.senderName || data.sender;
                    div.appendChild(nameSpan);
                }
                if (data.imageUrl) {
                    let img = document.createElement("img");
                    img.src = data.imageUrl;
                    img.className = "message-img";
                    img.onclick = () => openImageModal(data.imageUrl);
                    div.appendChild(img);
                }
                if (data.caption) {
                    let capSpan = document.createElement("div");
                    capSpan.innerText = data.caption;
                    capSpan.style.marginTop = "4px";
                    div.appendChild(capSpan);
                }
                if (data.text) {
                    let textSpan = document.createElement("div");
                    textSpan.innerText = data.text;
                    div.appendChild(textSpan);
                }
                if (data.audioUrl) {
                    let audioDiv = document.createElement("div");
                    audioDiv.className = "voice-message";
                    let playBtn = document.createElement("button");
                    playBtn.className = "voice-play-btn";
                    playBtn.innerHTML = "▶️";
                    let waveformDiv = document.createElement("div");
                    waveformDiv.className = "voice-waveform";
                    waveformDiv.innerHTML = createWaveform();
                    let durationSpan = document.createElement("span");
                    durationSpan.className = "voice-duration";
                    durationSpan.innerText = data.duration ? formatDuration(data.duration) : "0:00";
                    let audio = document.createElement("audio");
                    audio.src = data.audioUrl;
                    audio.style.display = "none";
                    playBtn.onclick = (e) => {
                        e.stopPropagation();
                        if (currentAudio && currentAudio !== audio) {
                            currentAudio.pause();
                            let prevBtn = currentAudio.parentElement?.querySelector('.voice-play-btn');
                            if (prevBtn) prevBtn.innerHTML = "▶️";
                        }
                        if (audio.paused) {
                            audio.play();
                            playBtn.innerHTML = "⏸️";
                            currentAudio = audio;
                            audio.onended = () => { playBtn.innerHTML = "▶️"; currentAudio = null; };
                        } else {
                            audio.pause();
                            playBtn.innerHTML = "▶️";
                        }
                    };
                    audio.addEventListener('loadedmetadata', () => {
                        if (data.duration) return;
                        let dur = Math.round(audio.duration);
                        durationSpan.innerText = formatDuration(dur);
                        db.collection("chats").doc(currentChatId).collection("messages").doc(doc.id).update({ duration: dur });
                    });
                    audioDiv.appendChild(playBtn);
                    audioDiv.appendChild(waveformDiv);
                    audioDiv.appendChild(durationSpan);
                    audioDiv.appendChild(audio);
                    div.appendChild(audioDiv);
                }
                let timeSpan = document.createElement("div");
                timeSpan.className = "message-time";
                timeSpan.innerText = data.time ? new Date(data.time.toDate()).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) : "только что";
                div.appendChild(timeSpan);
                if (isMy) {
                    let delBtn = document.createElement("div");
                    delBtn.className = "delete-msg";
                    delBtn.innerHTML = "✕";
                    delBtn.onclick = (e) => { e.stopPropagation(); deleteMessage(doc.id); };
                    div.appendChild(delBtn);
                }
                container.appendChild(div);
            });
            container.scrollTop = container.scrollHeight;
        });
    }

    async function deleteMessage(msgId) {
        if (confirm("Удалить сообщение?")) {
            await db.collection("chats").doc(currentChatId).collection("messages").doc(msgId).delete();
            showToast("Сообщение удалено");
        }
    }

    async function sendMessage() {
        let input = document.getElementById("messageInput");
        let text = input.value.trim();
        if (!text) return;
        let messagesRef = db.collection("chats").doc(currentChatId).collection("messages");
        await messagesRef.add({
            sender: currentUser, senderName: currentUserData?.name || currentUser,
            text: text, time: firebase.firestore.FieldValue.serverTimestamp()
        });
        await db.collection("chats").doc(currentChatId).update({ lastMessage: text, lastMessageTime: firebase.firestore.FieldValue.serverTimestamp() });
        input.value = "";
    }

    // Фото в чат
